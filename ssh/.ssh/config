# SSH Configuration
# Ensure you have the referenced identity files:
#   - ~/.ssh/id_ed25519 (GitHub)
#   - ~/.ssh/id_ed25519_gitlab_work (GitLab Work)

Host gitlab.com
  HostName gitlab.com
  User git
  IdentityFile ~/.ssh/id_ed25519_gitlab_work
  IdentitiesOnly yes

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

# Global defaults
Host *
  AddKeysToAgent yes
  ServerAliveInterval 60
  ServerAliveCountMax 3

