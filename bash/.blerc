# ============= fzf Integration =============
_ble_contrib_fzf_base=~/.fzf

# Load fzf integration modules (delayed for faster startup)
ble-import -d integration/fzf-completion
ble-import -d integration/fzf-key-bindings

# Configure fzf options after modules load
# Color theme: Tokyo Night
ble-import -C '
    export FZF_DEFAULT_OPTS="
        --height 40%
        --layout=reverse
        --border
        --inline-info
        --color=fg:#c0caf5,bg:#1a1b26,hl:#7aa2f7
        --color=fg+:#c0caf5,bg+:#292e42,hl+:#7dcfff
        --color=info:#7aa2f7,prompt:#7dcfff,pointer:#7dcfff
        --color=marker:#9ece6a,spinner:#9ece6a,header:#9ece6a"
    
    # Use fd for file search (faster, respects .gitignore)
    if command -v fdfind &> /dev/null; then
        export FZF_DEFAULT_COMMAND="fdfind --type f --hidden --follow --exclude .git"
        export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    fi
    
    # Use bat for file preview
    if command -v batcat &> /dev/null; then
        export FZF_CTRL_T_OPTS="--preview '\''batcat --color=always --style=plain --line-range :500 {}'\''"
    fi
' integration/fzf-key-bindings